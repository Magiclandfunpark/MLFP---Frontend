VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=magic-land-fun-park.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://magic-land-fun-park-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=magic-land-fun-park
VITE_FIREBASE_STORAGE_BUCKET=magic-land-fun-park.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=51445297408
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=default

# eSewa
# Use EPAYTEST + test secret for sandbox. Use the live merchant/service code +
# live secret for production. If ESEWA_PAYMENT_URL and ESEWA_VERIFY_URL are
# omitted, the API chooses sandbox for EPAYTEST and production otherwise.
ESEWA_ENV=test
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=
ESEWA_PAYMENT_URL=
ESEWA_VERIFY_URL=

# Khalti
# Use production for live merchant keys. Use test for sandbox keys.
KHALTI_ENV=production
KHALTI_SECRET_KEY=
KHALTI_PUBLIC_KEY=
KHALTI_INITIATE_URL=https://khalti.com/api/v2/epayment/initiate/
KHALTI_LOOKUP_URL=https://khalti.com/api/v2/epayment/lookup/

# Meta Conversions API
# Keep the token server-side only. Add these in Vercel Environment Variables.
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v23.0
# Optional: use while testing in Meta Events Manager > Test Events, then remove.
META_TEST_EVENT_CODE=
