{
  "rules": {
    "publicLiveStatus": {
      ".read": true,
      ".write": "auth != null && root.child('staff').child(auth.uid).exists()",
      "operatingStatus": {
        ".validate": "newData.isString() && newData.val().length <= 30"
      },
      "hours": {
        ".validate": "newData.isString() && newData.val().length <= 60"
      },
      "avgWait": {
        ".validate": "newData.isString() && newData.val().length <= 30"
      },
      "nextShow": {
        ".validate": "newData.isString() && newData.val().length <= 80"
      },
      "currentCapacity": {
        ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 700"
      },
      "maxCapacity": {
        ".validate": "newData.isNumber() && newData.val() == 700"
      },
      "$other": {
        ".validate": false
      }
    },
    "rideLiveStatus": {
      ".read": true,
      ".write": "auth != null && root.child('staff').child(auth.uid).exists()"
    },
    "publicRequests": {
      "$requestType": {
        ".read": "auth != null && root.child('staff').child(auth.uid).exists()",
        "$requestId": {
          ".write": "!data.exists() && ($requestType == 'bookingRequests' || $requestType == 'membershipRequests' || $requestType == 'contactRequests' || $requestType == 'eventRequests' || $requestType == 'newsletterSubscribers') && newData.child('status').val() == 'new' && newData.child('source').isString() && newData.child('createdAt').isString()",
          ".validate": true
        }
      }
    },
    "paymentReceipts": {
      "$gateway": {
        "$receiptId": {
          ".read": "auth != null && root.child('staff').child(auth.uid).exists()",
          ".write": "!data.exists() && auth != null && ($gateway == 'khalti' || $gateway == 'esewa') && newData.child('status').val() == 'verified' && newData.child('authUid').val() == auth.uid && newData.child('createdAt').isString()",
          ".validate": true
        }
      }
    },
    "staff": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": false
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "uid": {
          ".validate": "newData.val() == $uid"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length <= 120"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 180"
        },
        "phoneNumber": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "photoURL": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "providerIds": {
          ".validate": "newData.hasChildren() || newData.val() == null"
        },
        "lastSeenAt": {
          ".validate": "newData.isString()"
        },
        "visitorId": {
          ".validate": "newData.isString() && newData.val().length <= 140"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
